APP_NAME=Aalayam
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./aalayam.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Real-time vision (optional: webcam + YOLOv8) ---
# Only used when the vision extras are installed (requirements-vision.txt).
YOLO_MODEL=yolov8n.pt
CAMERA_SOURCE=0
CONFIDENCE_THRESHOLD=0.5
FRAME_SKIP=2
INFERENCE_INTERVAL=0.04
